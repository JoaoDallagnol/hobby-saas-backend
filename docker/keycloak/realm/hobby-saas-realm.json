{
  "realm": "hobby-saas",
  "enabled": true,
  "displayName": "Hobby SaaS Local",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "internationalizationEnabled": false,
  "clients": [
    {
      "clientId": "backend-local",
      "name": "Backend Local",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "secret": "backend-local-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8080"
      ]
    }
  ],
  "users": [
    {
      "username": "local-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "User",
      "email": "local-user@example.test",
      "credentials": [
        {
          "type": "password",
          "value": "local-user-password",
          "temporary": false
        }
      ]
    }
  ]
}
