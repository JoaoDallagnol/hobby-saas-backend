# Copy the variables you need into your local shell or a non-versioned `.env` file.
# Do not commit real credentials.
#
# Local:
# - DB_* and POSTGRES_* can use development values.
# - Firebase/R2/Google/Sentry/Brevo can stay empty while the real integration is not being exercised.
# - If you want to exercise protected endpoints before wiring a real Firebase dev project,
#   enable LOCAL_AUTH_* and use `Authorization: Bearer <LOCAL_AUTH_TOKEN>`.
# - Service account JSON, TLS certs and any real private key must stay outside git.
#
# Production:
# - Do not use this file directly on the server.
# - Inject real values as environment variables or secret files managed outside git.
# - For the production compose, also define APP_DOMAIN and the Nginx/HTTPS variables below.

SPRING_PROFILES_ACTIVE=local
SPRINGDOC_ENABLED=true

DB_URL=jdbc:postgresql://localhost:5432/hobby_saas
DB_USERNAME=backend
DB_PASSWORD=change-me
POSTGRES_DB=hobby_saas
POSTGRES_USER=backend
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=false
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_TOKENS=120
RATE_LIMIT_REFILL_MINUTES=1
FEATURE_PHOTO_UPLOADS_ENABLED=false
FEATURE_SESSION_LOCATION_ENABLED=false
FEATURE_PHOTO_PROCESSING_ENABLED=false
FEATURE_GAMIFICATION_ENABLED=true
FEATURE_PLUS_ENABLED=true
CWEBP_BINARY=/usr/bin/cwebp
PHOTO_PROCESSING_POLL_DELAY_MS=10000
PHOTO_DELETION_POLL_DELAY_MS=30000
PHOTO_VISIBILITY_POLL_DELAY_MS=5000
APP_DOMAIN=
APP_UPSTREAM=app:8080
SSL_CERTIFICATE_PATH=/etc/nginx/certs/fullchain.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/certs/privkey.pem
NGINX_CERTS_DIR=./deploy/nginx/certs
NGINX_CLIENT_MAX_BODY_SIZE=2m
NGINX_RATE_LIMIT_RPS=10r/s
NGINX_RATE_LIMIT_BURST=20

FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=

LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_TOKEN=
LOCAL_AUTH_USER_ID=local-dev-user
LOCAL_AUTH_EMAIL=local-dev@example.com
LOCAL_AUTH_NAME=Local Dev User
LOCAL_AUTH_EMAIL_VERIFIED=true
LOCAL_AUTH_SECONDARY_TOKEN=
LOCAL_AUTH_SECONDARY_USER_ID=local-secondary-user
LOCAL_AUTH_SECONDARY_EMAIL=local-secondary@example.com
LOCAL_AUTH_SECONDARY_NAME=Local Secondary User
LOCAL_AUTH_SECONDARY_EMAIL_VERIFIED=true

R2_ENDPOINT=
R2_PRESIGN_ENDPOINT=
R2_PRIVATE_BUCKET=
R2_PUBLIC_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ACCESS_KEY=
R2_SECRET_KEY=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Bucket privado separado para backups; o script operacional ainda usa R2_BUCKET.
R2_BUCKET=

GOOGLE_PLACES_API_KEY=
SENTRY_DSN=

BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=

BACKUP_PREFIX=postgres
BACKUP_DAILY_RETENTION=7
BACKUP_WEEKLY_RETENTION=4
BACKUP_WEEKLY_DAY_UTC=7
