# Copy the variables you need into your local shell or a non-versioned `.env` file.
# Do not commit real credentials.

SPRING_PROFILES_ACTIVE=local

DB_URL=jdbc:postgresql://localhost:5432/hobby_saas
DB_USERNAME=backend
DB_PASSWORD=change-me
POSTGRES_DB=hobby_saas
POSTGRES_USER=backend
POSTGRES_PASSWORD=change-me

KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/hobby-saas
KEYCLOAK_JWK_SET_URI=http://localhost:8081/realms/hobby-saas/protocol/openid-connect/certs
CORS_ALLOWED_ORIGINS=http://localhost:3000

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=


GOOGLE_PLACES_API_KEY=
SENTRY_DSN=

BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
