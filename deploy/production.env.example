# Copy this file outside git or to a non-versioned path before use in the VPS.
# Example:
#   cp deploy/production.env.example /opt/hobby-saas/prod.env
#   chmod 600 /opt/hobby-saas/prod.env
#   docker compose --env-file /opt/hobby-saas/prod.env -f docker-compose.prod.yml up -d --build
#
# Do not commit real values.

SPRING_PROFILES_ACTIVE=prod
SPRINGDOC_ENABLED=false

POSTGRES_DB=hobby_saas
POSTGRES_USER=backend
POSTGRES_PASSWORD=change-me

CORS_ALLOWED_ORIGINS=https://app.example.com

RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_TOKENS=120
RATE_LIMIT_REFILL_MINUTES=1

APP_DOMAIN=api.example.com
APP_UPSTREAM=app:8080
SSL_CERTIFICATE_PATH=/etc/nginx/certs/fullchain.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/certs/privkey.pem
NGINX_CERTS_DIR=/opt/hobby-saas/certs
NGINX_CLIENT_MAX_BODY_SIZE=2m
NGINX_RATE_LIMIT_RPS=10r/s
NGINX_RATE_LIMIT_BURST=20

FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=

GOOGLE_PLACES_API_KEY=
SENTRY_DSN=

BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=

BACKUP_PREFIX=postgres
BACKUP_DAILY_RETENTION=7
BACKUP_WEEKLY_RETENTION=4
BACKUP_WEEKLY_DAY_UTC=7
